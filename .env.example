# agent-memory — all local, nothing leaves your machine.

# Where the SQLite DB and cursor cache live. Defaults to a per-user data dir.
# RECALL_DB_PATH=C:\Users\you\.recall\memory.db

# Local daemon bind port (127.0.0.1 only).
RECALL_PORT=4319

# Embedding model (transformers.js id). 384-dim default.
RECALL_MODEL=Xenova/bge-small-en-v1.5

# Master switch for auto-inject. Set to false to disable injection instantly.
RECALL_ENABLED=true

# Minimum cosine similarity (0..1) for a snippet to be injected.
RECALL_MIN_SCORE=0.4
